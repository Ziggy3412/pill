# Backend API base URL
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google OAuth Client IDs
# Create these at https://console.cloud.google.com/apis/credentials
#
# Web client (also used in Expo Go for development):
#   Authorized JavaScript origins: http://localhost:3000
#   Authorized redirect URIs: https://auth.expo.io/@your-username/pillpal
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id_here

# iOS client (needed for production iOS builds):
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id_here

# Android client (needed for production Android builds):
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id_here
